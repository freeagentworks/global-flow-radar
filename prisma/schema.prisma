// Global Flow Radar - Prisma スキーマ
// 02_architecture.md 3.2節 データベース設計準拠

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 地域マスタ
model Region {
  id           String  @id @db.VarChar(10)
  nameEn       String  @map("name_en") @db.VarChar(100)
  nameJa       String  @map("name_ja") @db.VarChar(100)
  latitude     Decimal @db.Decimal(10, 6)
  longitude    Decimal @db.Decimal(10, 6)
  marketWeight Decimal @map("market_weight") @db.Decimal(6, 4)

  @@map("regions")
}

// セクターマスタ（GICS準拠）
model Sector {
  id                String @id @db.VarChar(30)
  nameEn            String @map("name_en") @db.VarChar(100)
  nameJa            String @map("name_ja") @db.VarChar(100)
  representativeEtf String @map("representative_etf") @db.VarChar(10)

  @@map("sectors")
}

// アラートルール
model AlertRule {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String?  @map("user_id") @db.VarChar(100)
  ruleName  String   @map("rule_name") @db.VarChar(200)
  flowType  String   @map("flow_type") @db.VarChar(20)
  targetId  String   @map("target_id") @db.VarChar(50)
  condition String   @db.VarChar(20)
  threshold Decimal  @db.Decimal(12, 4)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  alertHistory AlertHistory[]

  @@map("alert_rules")
}

// アラート履歴
model AlertHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId      String   @map("rule_id") @db.Uuid
  triggeredAt DateTime @map("triggered_at") @db.Timestamptz()
  flowValue   Decimal  @map("flow_value") @db.Decimal(18, 2)
  message     String?  @db.Text
  isRead      Boolean  @default(false) @map("is_read")

  rule AlertRule @relation(fields: [ruleId], references: [id])

  @@map("alert_history")
}

// NOTE: TimescaleDB hypertable（daily_flows, etf_flows, cot_positions, macro_indicators）は
// Prismaでは直接管理せず、マイグレーションSQLで作成する
// 理由: TimescaleDB固有のcreate_hypertable()はPrismaスキーマで表現できないため
